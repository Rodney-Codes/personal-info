# Optional cache-busting value for production builds.
# CI typically sets this automatically (for example to commit SHA).
VITE_SITE_DATA_BUST=

# Hosted docs-chatbot API (Render). No trailing slash.
# Leave empty for local client-only AMA (widget shows without health gate).
VITE_CHATBOT_API_BASE=

# Corpus loaded on the API (must match Render env CHATBOT_DEFAULT_CORPUS_ID).
VITE_CHATBOT_CORPUS_ID=default

# Backend answer settings (optional; API defaults are fine for zero-cost path).
VITE_CHATBOT_ALLOW_FALLBACK=true
VITE_CHATBOT_ANSWER_METHOD=lightweight_nlp
VITE_CHATBOT_RETRIEVAL_MODEL=

# Health gate while Render spins up (milliseconds).
VITE_CHATBOT_HEALTH_TIMEOUT_MS=180000
VITE_CHATBOT_HEALTH_ATTEMPT_MS=120000
