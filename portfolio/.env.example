# Optional cache-busting value for production builds.
# CI typically sets this automatically (for example to commit SHA).
VITE_SITE_DATA_BUST=

# Optional backend chat API (recommended for secure token usage and better responses).
# If unset, frontend uses static in-browser retrieval and tailored fallback.
VITE_CHATBOT_API_BASE=
VITE_CHATBOT_CORPUS_ID=default
# Set to false to disable backend fallback response shaping.
VITE_CHATBOT_ALLOW_FALLBACK=true
# Optional: force backend answer path for testing
# (hugging_face_lightweight_nlp | hugging_face | lightweight_nlp).
# Leave empty for normal behavior.
VITE_CHATBOT_ANSWER_METHOD=
# Optional: retrieval scorer
# (bm25 | hashed_vector | bm25_hashed_vector | rule_lexicon_tfidf).
# rule_lexicon_tfidf uses rule-lexicon TF-IDF cosine (heavier).
VITE_CHATBOT_RETRIEVAL_MODEL=

