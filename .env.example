# Backend chatbot env (local only). Copy to `.env` in repo root.

CHAT_ALLOW_FALLBACK=true
# Hugging Face OpenAI-compatible chat endpoint + model
HF_CHAT_API_URL=https://router.huggingface.co/v1/chat/completions
HF_MODEL=openai/gpt-oss-20b:fastest
# Optional retry list (comma-separated) if primary model/provider fails
HF_MODEL_FALLBACKS=meta-llama/Llama-3.1-8B-Instruct:novita
HF_API_TOKEN=
CORS_ALLOW_ORIGINS=http://localhost:5173

